#!/bin/bash

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    echo "Usage: sesh [session-name]"
    echo ""
    echo "  sesh              Open zoxide picker to select a directory and create/attach to a session"
    echo "  sesh [name]       Attach to an existing session or create one in the current directory"
    echo ""
    echo "If run inside zellij, opens a new terminal window and detaches from the current session."
    exit 0
fi

# If inside zellij, open a new alacritty with sesh
# then detach and kill previous alacritty window
if [[ -n "$ZELLIJ" ]]; then
    ALACRITTY_PID=$(xdotool getactivewindow getwindowpid)
    ZELLIJ="" alacritty --working-directory "$(pwd)" -e sesh "$@" &
    disown
    zellij action detach
    kill "$ALACRITTY_PID"
    exit 0
fi

# If an argument is provided, use it as session name
if [[ -n "$1" ]]; then
    SESSION_TITLE="$1"
    TARGET_DIR="$(pwd)"
else
    # Pick a directory with zoxide
    ZOXIDE_RESULT=$(zoxide query -i)
    if [[ -z "$ZOXIDE_RESULT" ]]; then
        # Fallback to common directories (can change/add relevant directories)
        ZOXIDE_RESULT=$(find ~/projects ~ -mindepth 1 -maxdepth 2 -type d 2>/dev/null | fzf)
    fi
    SESSION_TITLE=$(basename "$ZOXIDE_RESULT")
    TARGET_DIR="$ZOXIDE_RESULT"
fi

# Replace dots with underscores
SESSION_NAME=$(echo "$SESSION_TITLE"| tr . _)

cd "$TARGET_DIR"
zellij attach -c "$SESSION_NAME"
